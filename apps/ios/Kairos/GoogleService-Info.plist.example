<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Template. Copy to GoogleService-Info.plist and fill in with YOUR Firebase
  iOS app's values (Firebase console > Project settings > Your apps > iOS).
  The real file is gitignored — it carries the project's API key, which,
  while not truly secret (it is restricted by bundle id and ships in the
  app binary), is kept out of this open-source repo. Maintainers' CI drops
  the real file in from a secret.
-->
<plist version="1.0">
<dict>
	<key>CLIENT_ID</key>
	<string>000000000000-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com</string>
	<key>REVERSED_CLIENT_ID</key>
	<string>com.googleusercontent.apps.000000000000-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx</string>
	<key>API_KEY</key>
	<string>your-ios-api-key</string>
	<key>GCM_SENDER_ID</key>
	<string>000000000000</string>
	<key>PLIST_VERSION</key>
	<string>1</string>
	<key>BUNDLE_ID</key>
	<string>com.example.wellspring</string>
	<key>PROJECT_ID</key>
	<string>your-project</string>
	<key>STORAGE_BUCKET</key>
	<string>your-project.firebasestorage.app</string>
	<key>IS_ADS_ENABLED</key>
	<false></false>
	<key>IS_ANALYTICS_ENABLED</key>
	<false></false>
	<key>IS_APPINVITE_ENABLED</key>
	<true></true>
	<key>IS_GCM_ENABLED</key>
	<true></true>
	<key>IS_SIGNIN_ENABLED</key>
	<true></true>
	<key>GOOGLE_APP_ID</key>
	<string>1:000000000000:ios:0000000000000000000000</string>
</dict>
</plist>
