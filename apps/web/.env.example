# apps/web — copy to .env.local and fill in with YOUR Firebase project.
#
# None of these are secrets. The Firebase web config is a set of public
# project identifiers — the browser bundle publishes them by necessity.
# Access is gated by Firebase Auth's authorizedDomains and by the API
# verifying the ID token, not by keeping these values quiet. This repo
# ships placeholders only; supply your own project's values here (or, for
# the maintainers, they are injected at deploy from GitHub Actions vars).
#
# Get these from the Firebase console: Project settings > Your apps > (web app).
VITE_FIREBASE_API_KEY=your-web-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project
VITE_FIREBASE_APP_ID=1:000000000000:web:0000000000000000000000
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app

# Base URL of the /v1 API. Point at your own deployment, or a local server.
VITE_API_BASE_URL=http://localhost:8090
