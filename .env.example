# Kairos — credential template.
# Copy to `.env` (gitignored) and fill in real values LOCALLY. Never commit .env.
# `scripts/load-secrets.sh` reads this file and pushes values into GCP Secret Manager
# without printing them. Leave a line blank to skip that secret.

# --- Gloo AI (OAuth2 client credentials) ---
GLOO_CLIENT_ID=
GLOO_CLIENT_SECRET=

# --- YouVersion Platform (app key, X-YVP-App-Key header) ---
YOUVERSION_API_KEY=

# --- Google OAuth (calendar.events + calendar.freebusy) ---
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# --- Email invites (.ics path) ---
RESEND_API_KEY=

# --- LiveKit Cloud (room delivery, needed by W3) ---
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_URL=

# --- Optional: demo-video voice ---
ELEVENLABS_API_KEY=

# --- Internal API (POST /internal/generate-now shared-secret auth — issue #74) ---
# Placeholder auth (routes/internal.ts) standing in for real OIDC verification
# until Cloud Scheduler/Cloud Tasks call this route directly. Generate a long
# random value locally (e.g. `openssl rand -hex 32`).
INTERNAL_API_TOKEN=

# --- Cloud KMS key for refresh-token encryption (issue #22) ---
# Full CryptoKey resource name. Required for calendar-OAuth work — the API
# throws on startup if it's unset (no hardcoded fallback). Replace the
# placeholders with your own project / key-ring / key.
KMS_KEY_NAME=projects/your-gcp-project-id/locations/us-central1/keyRings/your-keyring/cryptoKeys/token-encryption
